# ------------------------
# --- TinyPKI settings ---
# ------------------------

# -- Seed with secure random values --
ATREST_ENCRYPTION_KEY={{ RAND_HEX_16 }}
SESSION_MIDDLEWARE_KEY={{ RAND_ASCII_32 }}
CSRF_PROTECT_MIDDLEWARE_KEY={{ RAND_ASCII_32 }}
PBKDF2_SALT={{ RAND_HEX_16 }}

# -- Application settings --
PBKDF2_ITERATIONS=600000

# How many certificates per page to display in "Certificates" view (and API)
CERTS_PER_PAGE=100

# TinyPKI offers public endpoints /public/api/crl, /public/api/roots, /public/api/intermediates
# which are proxied directly into respective Step CA endpoints
# this specifies how long (in seconds) we should cache the Step CA's response before updating it
# also controls the frequency of CRL re-fetch when validating certs for clients authenticating to TinyPKI
PUBLIC_PROXY_CACHE_INTERVAL=10

# How many seconds before the authenticating user's client certificate is fully revalidated
CLIENT_CERT_REVALIDATE_INTERVAL=60

# Specify Common Names (comma separated) that are allowed to use TinyPK
# right now there is no advanced permission management, just a single allowlist for all features together
TINYPKI_ALLOW_CERTS=step,tinyadmin

# Comma-separated list of names that are not allowed within Common Name/Subject Alternative Names,
# TinyPKI will refuse to issue such certificates through the invitations feature
# it's a good idea to specify the names of Step CA's admins/superadmins.
# By default, the admin is called "step".
TINYPKI_DISALLOWED_NAMES=step

# The address where the Step CA software is running
TINYPKI_STEP_CA_URL=https://ca:9000

# SHA-256 fingerprint of the Step CA's root certificate,
# if not provided, will accept any fingerprint!
TINYPKI_STEP_CA_ROOT_FINGERPRINT=

# Only for development, DON'T ENABLE ON PRODUCTION
# forces the application to assume that the user is authenticated with a specific subject name
# UNSAFE_OVERRIDE_CLIENT_CN={"Common Name": "tinyadmin"}
