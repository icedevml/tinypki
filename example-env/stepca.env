# ---------------
# --- Step CA ---
# ---------------

DOCKER_STEPCA_INIT_NAME=Smallstep
DOCKER_STEPCA_INIT_DNS_NAMES=localhost,ca
DOCKER_STEPCA_INIT_ACME=true
DOCKER_STEPCA_INIT_PROVISIONER_NAME=admin
DOCKER_STEPCA_INIT_PASSWORD_FILE=/run/secrets/password

DOCKER_TINYPKI_CRL_ENABLE=1
DOCKER_TINYPKI_CRL_GENERATE_ON_REVOKE=1
# DOCKER_TINYPKI_CRL_IDP_URL=https://example.com/1.0/crl
# DOCKER_TINYPKI_CRL_CACHE_DURATION=24h
# DOCKER_TINYPKI_CRL_RENEW_PERIOD=16h
